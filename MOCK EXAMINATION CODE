initial_choice PROC
    call clrscr
    mov edx, OFFSET WelcomeMsg
    call WriteString
    call crlf
    call crlf
    
initial_prompt_loop:
    mov edx, OFFSET initial_prompt
    call WriteString
    
    mov edx, OFFSET input
    mov ecx, 2
    call ReadString
    
    mov al, [input]
    cmp al, '1'
    je sign_in_selected
    cmp al, '2'
    je register_selected
    
    ; Invalid input
    mov edx, OFFSET invalid_choice_msg
    call WriteString
    call crlf
    jmp initial_prompt_loop

sign_in_selected:
    INVOKE login
    ret

register_selected:
    call register_user
    mov edx, OFFSET registration_success
    call WriteString
    call crlf
    call WaitMsg
    call clrscr
    ret
initial_choice ENDP

validate_subject_choice PROC
    cmp eax,1
    jl invalid_subject
    cmp eax,7    
    jg invalid_subject
    clc 
    ret
    
invalid_subject:
    mov edx,OFFSET invalid_subject_msg
    call WriteString
    call crlf
    call crlf
    stc  
    ret
validate_subject_choice ENDP

get_valid_answer PROC
answer_input:
    mov edx,OFFSET userPrompt
    call WriteString
    
    mov edx,OFFSET buffer1
    mov ecx,buffersize
    call ReadString
    cmp eax, 0
    je empty_input
    
    cmp eax,1
    jne invalid_answer
    
    mov al,buffer1
    cmp al,'A'
    je valid_answer
    cmp al,'B'
    je valid_answer
    
    jmp invalid_answer

empty_input:
    mov edx,OFFSET empty_input_msg
    call WriteString
    call crlf
    jmp answer_input

invalid_answer:
    mov edx,OFFSET invalid_answer_msg
    call WriteString
    call crlf
    jmp answer_input

valid_answer:
    ret
get_valid_answer ENDP

Result PROC
    cmp al,buffer1
    je correct
    jmp incorrect
    correct:
    mov edx,OFFSET correctMessage
    call WriteString
    inc score
    call crlf
    ret
    
incorrect:
    mov edx,OFFSET incorrectMessage
    call WriteString
    call crlf
    ret
Result ENDP

get_random_question PROC
    push ecx
    mov ecx, 7                    
    call find_unasked_question
    cmp eax, -1
    jne found_question
    
    ; All questions asked, reset flags
    mov esi, OFFSET question_flags
    mov ecx, 7                    
reset_flags:
    mov byte ptr [esi], 0
    inc esi
    loop reset_flags
    call find_unasked_question

found_question:
    pop ecx
    ret
get_random_question ENDP
find_unasked_question PROC
    push ecx
    push ebx
    mov ecx, 0
    
try_again:
    mov eax, 7                  
    call RandomRange
    
    ; Check if question already asked
    mov ebx, OFFSET question_flags
    add ebx, eax
    cmp byte ptr [ebx], 0
    je found_unasked
    
    inc ecx
    cmp ecx, 35                
    jl try_again
    
    ; If we can't find an unasked question, find the first available one
    mov ecx, 0
find_first_available:
    mov ebx, OFFSET question_flags
    add ebx, ecx
    cmp byte ptr [ebx], 0
    je found_forced
    inc ecx
    cmp ecx, 7                    
    jl find_first_available
    mov eax, -1
    jmp done
    
found_forced:
    mov eax, ecx
    jmp mark_question
    
found_unasked:
    ; Continue with marking the question
    
mark_question:
    mov byte ptr [ebx], 1         ; Mark as asked
    mov current_question_index, eax
    
done:
    pop ebx
    pop ecx
    ret
find_unasked_question ENDP

display_analysis PROC
    call crlf
    mov edx, OFFSET analysis_header
    call WriteString
    call crlf
    mov edx, OFFSET separator_line
    call WriteString
    call crlf
    mov edx, OFFSET question_header
    call WriteString
    call crlf
    mov edx, OFFSET separator_line
    call WriteString
    call crlf
    
    ; Display each question result
    mov ecx, 0
analysis_loop:
    cmp ecx, 7                    
    jge analysis_done
    
    ; Display question number
    mov eax, ecx
    inc eax
    call WriteDec
    mov al, ' '
    call WriteChar
    call WriteChar
    call WriteChar
    
    ; Display user's answer
    mov esi, OFFSET user_answers
    add esi, ecx
    mov al, [esi]
    call WriteChar
    mov al, ' '
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    
    ; Display correct answer
    mov esi, OFFSET correct_answers
    add esi, ecx
    mov al, [esi]
    call WriteChar
    mov al, ' '
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    call WriteChar
    
    mov esi, OFFSET user_answers
    add esi, ecx
    mov al, [esi]
    mov esi, OFFSET correct_answers
    add esi, ecx
    mov bl, [esi]
    cmp al, bl
    je show_correct
    
    mov edx, OFFSET incorrectMessage
    call WriteString
    jmp next_question
    
show_correct:
    mov edx, OFFSET correctMessage
    call WriteString
    
next_question:
    call crlf
    inc ecx
    jmp analysis_loop
    
analysis_done:
    call crlf
    
    mov edx, OFFSET correct_count_msg
    call WriteString
    mov eax, score
    call WriteDec
    call crlf
    
    mov edx, OFFSET incorrect_count_msg
    call WriteString
    mov eax, 7                   
    sub eax, score
    call WriteDec
    call crlf
    
    mov edx, OFFSET percentage_msg
    call WriteString
    mov eax, score
    imul eax, 100
    cdq
    mov ebx, 7                  
    idiv ebx
    call WriteDec
    mov edx, OFFSET percent_sign
    call WriteString
    call crlf
    call crlf
    
    ret
display_analysis ENDP

login PROC
enter 0,0
login_start:
    mov eax, attempt_count
    cmp eax, max_attempts
    jge too_many_attempts
    
    mov edx,OFFSET username_prompt
    call WriteString
    mov edx,OFFSET input           
    mov ecx,SIZEOF input
    call ReadString
    
    mov esi,OFFSET username
    mov edi,OFFSET input
    call compare_strings
    jc login_failed

    mov edx,OFFSET password_prompt
    call WriteString
    mov edx,OFFSET input            
    mov ecx,SIZEOF input
    call ReadString
    
    mov esi,OFFSET password
    mov edi,OFFSET input
    call compare_strings
    jc login_failed

    mov edx,OFFSET success_message
    call WriteString
    call crlf
    call WaitMsg
    call clrscr
    leave
    ret

login_failed:
    inc attempt_count 
    
    mov edx,OFFSET failure_message
    call WriteString
    call crlf
    
    ; Show remaining attempts
    mov eax, max_attempts
    sub eax, attempt_count
    call WriteDec
    mov edx, OFFSET attempts_remaining_msg  
    call WriteString
    call crlf
    
    call WaitMsg
    call clrscr
    jmp login_start

too_many_attempts:
    call crlf
    mov edx, OFFSET goodbye_msg 
    call WriteString
    call crlf
    call WaitMsg
    leave
    ret
login ENDP

register_user PROC
    call clrscr
    mov edx, OFFSET WelcomeMsg
    call WriteString
    call crlf
    call crlf
    
    mov edx,OFFSET new_username_prompt
    call WriteString
    mov edx,OFFSET input             
    mov ecx,SIZEOF input
    call ReadString
    
    ; Copy new username using simple loop
    mov esi, OFFSET input
    mov edi, OFFSET username
copy_username_loop:
    mov al, [esi]
    mov [edi], al
    inc esi
    inc edi
    cmp al, 0
    jne copy_username_loop
    
    mov edx,OFFSET new_password_prompt
    call WriteString
    mov edx,OFFSET input             
    mov ecx,SIZEOF input
    call ReadString
    
    ; Copy new password using simple loop
    mov esi, OFFSET input
    lea edi, password
copy_password_loop:
    mov al, [esi]
    mov [edi], al
    inc esi
    inc edi
    cmp al, 0
    jne copy_password_loop
    
    mov attempt_count, 0
    ret
register_user ENDP

compare_strings PROC    
compare_loop:
    mov al,[esi]
    mov bl,[edi]
    
    cmp al, bl
    jne strings_not_equal
    cmp al, 0
    je strings_equal
    
    inc esi
    inc edi
    jmp compare_loop

strings_not_equal:
    stc    
    ret

strings_equal:
    clc   
    ret
compare_strings ENDP

reset_question_flags PROC
    push esi
    push ecx
    
    mov esi, OFFSET question_flags
    mov ecx, 7
reset_loop:
    mov byte ptr [esi], 0
    inc esi
    loop reset_loop
    
    pop ecx
    pop esi
    ret
reset_question_flags ENDP

ask_continue PROC
    call crlf
    mov edx, OFFSET continue_prompt
    call WriteString
    
ask_continue_input:
    mov edx, OFFSET input
    mov ecx, 2
    call ReadString
    
    mov al, [input]
    cmp al, 'Y'
    je continue_yes
    cmp al, 'y'
    je continue_yes
    cmp al, 'N'
    je continue_no
    cmp al, 'n'
    je continue_no
    
    mov edx, OFFSET invalid_continue_msg
    call WriteString
    call crlf
    jmp ask_continue_input

continue_yes:
    call clrscr
    mov score, 0
    call reset_question_flags
    ret    

continue_no:
    call crlf
    mov edx, OFFSET thank_you_msg
    call WriteString
    call crlf
    call crlf
    mov edx, OFFSET scoremsg
    call WriteString
    mov eax, score
    call WriteInt
    call crlf
    call WaitMsg
    exit    
ask_continue ENDP

end main
